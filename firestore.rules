rules_version = '2';

// ────────────────────────────────────────────────────────────────────
// ewoo-clinical Firestore 보안 규칙
// ────────────────────────────────────────────────────────────────────
// 원칙:
//   이 앱은 모든 Firestore I/O를 서버(Next.js API routes, firebase-admin)로 처리.
//   클라이언트에서 firestore SDK 직접 호출 0건 (2026-04-20 audit 기준).
//   admin SDK는 보안 규칙을 우회하므로 서버 동작에 영향 없음.
//
// 정책:
//   클라이언트 직접 접근 전면 차단. 향후 client 접근 필요 시 해당 컬렉션만
//   명시적 match 블록 추가 + 리뷰.
// ────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
